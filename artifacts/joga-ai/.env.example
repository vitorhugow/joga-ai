# Joga AI — variáveis de ambiente (copiar para `.env.local`)

# Firebase (obrigatório para auth + Firestore em produção)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Push notifications (opcional — Firebase Console → Cloud Messaging → Web Push certificates)
VITE_FIREBASE_VAPID_KEY=

# Vite dev/build (obrigatório localmente)
PORT=5173
BASE_PATH=/
