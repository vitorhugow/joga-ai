# Joga AI — variáveis de ambiente (copiar para `.env.local`)

# Firebase (obrigatório para auth + Firestore em produção)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Firebase Cloud Messaging — Web Push (par de chaves VAPID no Console)
VITE_FIREBASE_VAPID_KEY=

# Firebase App Check — reCAPTCHA v3 site key (modo MONITOR no arranque)
VITE_RECAPTCHA_SITE_KEY=

# UIDs com acesso ao painel /admin (separados por vírgula)
VITE_ADMIN_UIDS=KrnnjgKclcPJm4In4W9ORp3iX6j2

# Vite dev/build (obrigatório localmente)
PORT=5173
BASE_PATH=/
