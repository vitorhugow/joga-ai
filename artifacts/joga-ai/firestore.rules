rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isCommunityAdmin(communityId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/communities/$(communityId)).data.adminId == request.auth.uid;
    }

    function matchDoc(matchId) {
      return get(/databases/$(database)/documents/matches/$(matchId)).data;
    }

    function isMatchOrganizer(matchId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/matches/$(matchId))
        && matchDoc(matchId).organizerId == request.auth.uid;
    }

    // Administradores da app (painel /admin — PRO manual sem Stripe)
    function isAppAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'KrnnjgKclcPJm4In4W9ORp3iX6j2'
        || request.auth.token.email == 'vh.santos.nunes@gmail.com'
        || (exists(/databases/$(database)/documents/appConfig/admins)
            && request.auth.uid in get(/databases/$(database)/documents/appConfig/admins).data.uids)
      );
    }

    function isAdminUserMaintenanceUpdate() {
      return isAppAdmin()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['entitlements', 'unlockedSkins', 'updatedAt']);
    }

    function validNotificationCreate() {
      return request.resource.data.keys().hasOnly(
          ['title', 'body', 'type', 'link', 'read', 'createdAt', 'priority']
        )
        && request.resource.data.read == false
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 80
        && request.resource.data.body is string
        && request.resource.data.body.size() <= 240
        && (!('type' in request.resource.data)
          || request.resource.data.type in ['match', 'community', 'system'])
        && (!('priority' in request.resource.data)
          || request.resource.data.priority in ['popup', 'center']);
    }

    function canCreateClientNotification(ownerId, notifId) {
      return isOwner(ownerId)
        || notifId.matches('^vote-.+')
        || notifId.matches('^promoted-.+');
    }

    // Collection-group queries (loadMyCommunities, pedidos pendentes)
    // Apenas leitura: este wildcard existe para as collection-group queries.
    // Criação/remoção de membros acontece SÓ no bloco communities/{id}/members.
    match /{path=**}/members/{memberId} {
      allow read: if isSignedIn()
        && (memberId == request.auth.uid
          || resource.data.userId == request.auth.uid);
    }

    match /{path=**}/joinRequests/{requestUserId} {
      allow read: if isSignedIn() && requestUserId == request.auth.uid;
      allow create: if isSignedIn() && requestUserId == request.auth.uid;
    }

    function isCommunityMatchMember(communityId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid));
    }

    function communityDoc(communityId) {
      return get(/databases/$(database)/documents/communities/$(communityId)).data;
    }

    function isCommunityOpenToExternal(communityId) {
      return communityDoc(communityId).openToExternal == true
        && communityDoc(communityId).proActive == true;
    }

    function isMatchRsvpUpdate() {
      let data = resource.data;
      return isSignedIn()
        && (!('communityId' in data) || data.communityId == null
            || isCommunityOpenToExternal(data.communityId)
            || isCommunityMatchMember(data.communityId))
        && request.resource.data.organizerId == resource.data.organizerId
        && request.resource.data.status == resource.data.status
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['players', 'participantUserIds', 'waitlist', 'playerTeams', 'assignments', 'savedAt']);
    }

    function isCommunityMatchRsvpUpdate(matchId) {
      let data = matchDoc(matchId);
      return isSignedIn()
        && data.communityId is string
        && isCommunityMatchMember(data.communityId)
        && request.resource.data.organizerId == resource.data.organizerId
        && request.resource.data.status == resource.data.status
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['players', 'participantUserIds', 'waitlist', 'playerTeams', 'assignments', 'savedAt']);
    }

    // Qualquer participante presente (não só o organizador) pode fechar a
    // partida ao vivo e mandá-la para votação — evita ficar presa em "ao_vivo"
    // quando quem termina não é o organizador.
    function isMatchLiveEndUpdate(matchId) {
      let data = matchDoc(matchId);
      return isSignedIn()
        && data.status == 'ao_vivo'
        && request.resource.data.status == 'aguardando_auditoria'
        && request.resource.data.organizerId == resource.data.organizerId
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            'status', 'miniGames', 'players', 'participantUserIds', 'playerTeams',
            'currentPlayerId', 'assignments', 'savedAt',
            'votedUserIds', 'waitlist', 'title', 'communityId', 'organizerId'
          ]);
    }

    // Finalizar a votação (todos votaram, ou o prazo de 24h expirou) precisa
    // de funcionar mesmo quando quem dispara a transição não é o organizador
    // — normalmente é o último jogador a votar. Só permite mudar para
    // "concluida" a partir da fase de votação, sem tocar em mais nada.
    function isMatchVotingFinalizeUpdate(matchId) {
      let data = matchDoc(matchId);
      return isSignedIn()
        && (data.status == 'aguardando_auditoria' || data.status == 'auditada')
        && request.resource.data.status == 'concluida'
        && request.resource.data.organizerId == resource.data.organizerId
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'savedAt', 'votedUserIds']);
    }

    // Cada jogador marca-se a si próprio como tendo votado (arrayUnion do
    // seu próprio uid); não altera status/organizador nem remove ninguém
    // já presente na lista. Só é possível enquanto a pelada ainda está em
    // votação — uma vez "concluida", ninguém mais pode registar voto.
    function isMatchVoteMarkUpdate() {
      return isSignedIn()
        && (resource.data.status == 'aguardando_auditoria' || resource.data.status == 'auditada')
        && request.resource.data.status == resource.data.status
        && request.resource.data.organizerId == resource.data.organizerId
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['votedUserIds', 'savedAt'])
        && request.resource.data.votedUserIds.hasAll(resource.data.get('votedUserIds', []))
        && request.resource.data.votedUserIds.hasAny([request.auth.uid]);
    }

    // Configuração da app gerida pela consola (ex.: patrocinador do SponsorSlot)
    match /appConfig/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isSignedIn();
      // entitlements (PRO) é concedido por Cloud Functions (Stripe) ou admin da app.
      allow create: if isOwner(userId)
        && !request.resource.data.keys().hasAny(['entitlements', 'peladaBalanceCents']);
      // Revert de evolução: só o organizador da partida, só os campos do revert,
      // e apenas se o user realmente participou dessa partida (tem matchHistory dela).
      allow update: if (
        isOwner(userId)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['entitlements', 'peladaBalanceCents'])
      ) || isAdminUserMaintenanceUpdate() || (
        isSignedIn()
        && request.resource.data.keys().hasAll(['_revertForMatchId'])
        && isMatchOrganizer(request.resource.data._revertForMatchId)
        && exists(/databases/$(database)/documents/users/$(userId)/matchHistory/$(request.resource.data._revertForMatchId))
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['attributes', 'seasonStats', '_revertForMatchId', 'updatedAt',
                    'lastAttributeDeltas', 'lastEvolutionMatchId', 'lastMatchRating'])
      ) || (
        // Ganho de participação (+1 Físico) e distintivos aplicados a TODO o
        // plantel por quem termina a partida ao vivo — normalmente o
        // organizador. Restrito ao organizador da partida real referida e a
        // uma lista fechada de campos (nunca nome, foto, entitlements, etc.
        // — corrige a vulnerabilidade em que qualquer signed-in user podia
        // reescrever o perfil inteiro de qualquer pessoa via este marcador).
        isSignedIn()
        && request.resource.data.keys().hasAll(['_applyForMatchId'])
        && isMatchOrganizer(request.resource.data._applyForMatchId)
        // O alvo tem de ter participado DESSA partida — sem isto, qualquer
        // pessoa criava uma pelada própria e reescrevia atributos/badges de
        // qualquer utilizador da app.
        && userId in matchDoc(request.resource.data._applyForMatchId)
          .get('participantUserIds', [])
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['attributes', 'seasonStats', '_applyForMatchId', 'updatedAt',
                    'lastAttributeDeltas', 'lastEvolutionMatchId', 'lastMatchRating', 'badges'])
      );
      allow delete: if false;

      match /evolution/{recordId} {
        allow read, write: if isOwner(userId);
        allow delete: if isOwner(userId)
          || (isSignedIn()
            && resource.data.matchId is string
            && isMatchOrganizer(resource.data.matchId));
      }

      match /matchHistory/{histMatchId} {
        allow read, write: if isOwner(userId);
        allow delete: if isOwner(userId) || isMatchOrganizer(histMatchId);
      }

      match /notifications/{notifId} {
        allow read, update, delete: if isOwner(userId);
        allow create: if isSignedIn()
          && validNotificationCreate()
          && canCreateClientNotification(userId, notifId);
      }

      match /fcmTokens/{tokenId} {
        allow read, write: if isOwner(userId);
      }

      match /blocked/{targetUid} {
        allow read, write: if isOwner(userId);
      }
    }

    match /reports/{reportId} {
      function validReportCreate() {
        return request.resource.data.keys().hasOnly(
            ['reporterId', 'targetType', 'targetId', 'reason', 'details', 'status', 'createdAt']
          )
          && request.resource.data.reporterId == request.auth.uid
          && request.resource.data.status == 'open'
          && request.resource.data.targetType in ['user', 'community']
          && request.resource.data.reason in [
            'nome_ofensivo', 'foto_inapropriada', 'comportamento', 'spam', 'outro'
          ]
          && request.resource.data.targetId is string
          && request.resource.data.targetId.size() > 0
          && request.resource.data.targetId.size() <= 128
          && request.resource.data.details is string
          && request.resource.data.details.size() <= 500;
      }

      allow create: if isSignedIn() && validReportCreate();
      allow read, update: if isAppAdmin();
      allow delete: if false;
    }

    match /rateLimits/{docId} {
      allow read, write: if false;
    }

    match /matches/{matchId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.organizerId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.organizerId == request.auth.uid
        || (
          resource.data.currentPlayerId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['currentPlayerId', 'players', 'participantUserIds', 'savedAt'])
        )
        || isMatchRsvpUpdate()
        || isCommunityMatchRsvpUpdate(matchId)
        || isMatchLiveEndUpdate(matchId)
        || isMatchVotingFinalizeUpdate(matchId)
        || isMatchVoteMarkUpdate()
      );
      allow delete: if isSignedIn()
        && resource.data.organizerId == request.auth.uid;

      match /auditors/{docId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isSignedIn() && (
          isMatchOrganizer(matchId)
          || resource.data.userId == request.auth.uid
        );
      }

      match /votes/{userId} {
        allow read: if isSignedIn();
        allow create, update: if isOwner(userId);
        allow delete: if isMatchOrganizer(matchId);
      }

      match /events/{eventId} {
        allow read: if isSignedIn();
        allow write: if isMatchOrganizer(matchId);
      }

      match /miniGames/{gameId} {
        allow read: if isSignedIn();
        allow write: if isMatchOrganizer(matchId);
      }

      match /summary/{docId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && (
          isMatchOrganizer(matchId)
          || matchDoc(matchId).status in ['aguardando_auditoria', 'auditada', 'concluida']
        );
      }
    }

    match /communities/{communityId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.adminId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.adminId == request.auth.uid
        || (
          !resource.data.isPrivate
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberCount'])
          && request.resource.data.memberCount == resource.data.memberCount + 1
        )
      );
      allow delete: if isSignedIn() && resource.data.adminId == request.auth.uid;

      match /members/{memberId} {
        allow read: if isSignedIn();
        // Self-join só em comunidades públicas; em privadas, só o admin
        // (via aprovação de joinRequest) pode criar o membro.
        allow create: if isSignedIn() && (
          isCommunityAdmin(communityId)
          || (
            memberId == request.auth.uid
            && get(/databases/$(database)/documents/communities/$(communityId)).data.isPrivate != true
          )
        );
        allow update: if isCommunityAdmin(communityId);
        allow delete: if isCommunityAdmin(communityId)
          || (isSignedIn() && memberId == request.auth.uid);
      }

      match /joinRequests/{requestUserId} {
        allow read: if isSignedIn() && (
          requestUserId == request.auth.uid
          || isCommunityAdmin(communityId)
        );
        allow create: if isSignedIn() && requestUserId == request.auth.uid;
        allow update: if isSignedIn() && (
          requestUserId == request.auth.uid
          || isCommunityAdmin(communityId)
        );
        allow delete: if isCommunityAdmin(communityId);
      }

      match /rivalries/{pairId} {
        allow read: if isSignedIn();
        allow write: if isCommunityMatchMember(communityId)
          || isCommunityAdmin(communityId);
      }

      match /mensalistas/{mensalistaUid} {
        allow read: if isSignedIn()
          && (isCommunityMatchMember(communityId) || isCommunityAdmin(communityId));
        allow write: if false;
      }
    }
  }
}
