rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isCommunityAdmin(communityId) {
      let data = firestore.get(/databases/(default)/documents/communities/$(communityId)).data;
      return isSignedIn()
        && (data.adminId == request.auth.uid || request.auth.uid in data.get('adminIds', []));
    }

    function isValidBrandingImage() {
      return request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType in ['image/png', 'image/jpeg', 'image/webp'];
    }

    function isAppAdmin() {
      return request.auth != null && (
        request.auth.uid == 'KrnnjgKclcPJm4In4W9ORp3iX6j2'
        || request.auth.token.email == 'vh.santos.nunes@gmail.com'
        || (firestore.exists(/databases/(default)/documents/appConfig/admins)
            && request.auth.uid in firestore.get(/databases/(default)/documents/appConfig/admins).data.uids)
      );
    }

    match /app/fieldPhotos/{fileName} {
      allow read: if true;
      allow write: if isAppAdmin() && isValidBrandingImage();
      allow delete: if isAppAdmin();
    }

    match /communities/{communityId}/branding/{fileName} {
      allow read: if isSignedIn();
      allow write: if isCommunityAdmin(communityId) && isValidBrandingImage();
      allow delete: if isCommunityAdmin(communityId);
    }

    match /users/{uid}/avatar/{fileName} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == uid && isValidBrandingImage();
      allow delete: if isSignedIn() && request.auth.uid == uid;
    }

    match /communities/{communityId}/cover/{fileName} {
      allow read: if true;
      allow write: if isCommunityAdmin(communityId) && isValidBrandingImage();
      allow delete: if isCommunityAdmin(communityId);
    }
  }
}
